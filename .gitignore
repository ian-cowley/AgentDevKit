## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leasePublic/
x64/
x86/
build/
bin/
obj/

# Visual Studio 2015/2017/2019/2022 cache files
.vs/

# SQL Server files
*.mdf
*.ldf
*.ndf

# SQLite database files
*.db
*.db-shm
*.db-wal

# Log files
*.log
telemetry.log

# Project specific sessions
agent_sessions.db

# Others
/test/
/docs/images/*.png
/docs/images/*.jpg
/docs/images/*.jpeg
/docs/images/*.gif
